{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "carbon",
      "camelcase": "Carbon",
      "title": "Carbon",
      "scope": "source.carbon",
      "file-types": ["carbon"],
      "injection-regex": "^carbon$",
      "class-name": "TreeSitterCarbon"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Carbon grammar for tree-sitter",
    "authors": [
      {
        "name": "Carbon Developers",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/Aaron-212/tree-sitter-carbon",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": false,
    "zig": false
  }
}
